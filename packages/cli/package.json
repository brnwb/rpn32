{
  "name": "@brnwb/rpn32-cli",
  "version": "0.3.1",
  "description": "A terminal RPN calculator inspired by the HP 32SII",
  "homepage": "https://github.com/brnwb/rpn32#readme",
  "bugs": {
    "url": "https://github.com/brnwb/rpn32/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brnwb/rpn32.git",
    "directory": "packages/cli"
  },
  "bin": {
    "rpn32": "dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/app.js",
  "types": "./dist/app.d.ts",
  "exports": {
    ".": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    }
  },
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "pnpm run clean && tsc -p tsconfig.json && chmod +x dist/bin.js",
    "dev": "tsx src/bin.ts",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@brnwb/rpn32-core": "workspace:*",
    "@types/node": "^24.10.1"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
