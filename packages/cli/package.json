{
  "name": "@brnwb/rpn32-cli",
  "version": "0.5.1",
  "description": "A terminal RPN calculator inspired by the HP 32SII",
  "homepage": "https://github.com/brnwb/rpn32#readme",
  "bugs": {
    "url": "https://github.com/brnwb/rpn32/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brnwb/rpn32.git",
    "directory": "packages/cli"
  },
  "bin": {
    "rpn32": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "exports": {},
  "scripts": {
    "clean": "rm -rf dist tsconfig.tsbuildinfo",
    "build": "pnpm run clean && tsc -p tsconfig.json && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@brnwb/rpn32-core": "workspace:*"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
