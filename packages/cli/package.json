{
  "name": "rpn32",
  "version": "0.1.0",
  "description": "A terminal RPN calculator inspired by the HP 32SII",
  "license": "MIT",
  "bin": {
    "rpn32": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/cli.js",
