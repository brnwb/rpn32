#!/usr/bin/env bash
set -euo pipefail

node_version="22.13.0"
corepack_version="0.34.5"
node_dir="$HOME/.local/share/node-v${node_version}-linux-x64"
node_bin="$node_dir/bin"

# The orb-provided Node.js is older than the minimum required by pnpm 11.
echo "Ensuring Node.js ${node_version}..."
if [[ ! -x "$node_bin/node" ]]; then
  archive="$(mktemp --suffix=.tar.xz)"
  trap 'rm -f "$archive"' EXIT
  curl --fail --location --silent --show-error \
    "https://nodejs.org/dist/v${node_version}/node-v${node_version}-linux-x64.tar.xz" \
    --output "$archive"
  mkdir -p "$node_dir"
  tar -xJf "$archive" --strip-components=1 -C "$node_dir"
fi

# Lifecycle scripts cannot alter the environment of later agent shells. Put the
# selected Node.js first on the orb's existing PATH via ~/.local/bin.
mkdir -p "$HOME/.local/bin"
ln -sfn "$node_bin/node" "$HOME/.local/bin/node"
export PATH="$HOME/.local/bin:$node_bin:$PATH"

echo "Enabling the packageManager-pinned pnpm version..."
# Node 22.13 ships a Corepack release whose stale signing keys cannot verify
# current pnpm releases.
if [[ ! -x "$node_bin/corepack" ]] || \
  [[ "$("$node_bin/corepack" --version)" != "$corepack_version" ]]; then
  "$node_bin/npm" install --global --no-audit --no-fund "corepack@$corepack_version"
fi
ln -sfn "$node_bin/corepack" "$HOME/.local/bin/corepack"
corepack enable pnpm --install-directory "$HOME/.local/bin"

echo "Installing workspace dependencies..."
pnpm install --frozen-lockfile

# Keep the orb's existing shared hooks (such as commit attribution) and add a
# dispatcher that runs a repository-owned pre-push hook when one exists.
echo "Installing repository Git hooks..."
hooks_path="$(git config --path --get core.hooksPath || git rev-parse --git-path hooks)"
mkdir -p "$hooks_path"
pre_push_dispatcher="$hooks_path/pre-push"

if [[ ! -e "$pre_push_dispatcher" ]] || grep -q "rpn32 repository hook dispatcher" "$pre_push_dispatcher"; then
  cat > "$pre_push_dispatcher" <<'EOF'
#!/bin/sh
# rpn32 repository hook dispatcher
set -eu

repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
repo_hook="$repo_root/.githooks/pre-push"

if [ -n "$repo_root" ] && [ -x "$repo_hook" ]; then
  exec "$repo_hook" "$@"
fi
EOF
  chmod +x "$pre_push_dispatcher"
else
  echo "Existing pre-push hook preserved; install .githooks/pre-push manually if needed."
fi
