#!/bin/sh
set -eu

pushes_main=0

while read -r _local_ref _local_oid remote_ref _remote_oid; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    pushes_main=1
  fi
done

if [ "$pushes_main" -eq 0 ]; then
  exit 0
fi

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

echo "Running pre-push checks for main..."
pnpm run check
